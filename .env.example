# Copy to .env and fill in real values for local dev. On Railway, set these in the
# service's Variables tab instead. .env is gitignored; .env.example is committed.

# Required secrets
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SUPABASE_KEY=your-supabase-anon-key

# Optional (config.py has a default)
SUPABASE_URL=https://your-project.supabase.co

# Gmail OAuth token JSON on ONE line — the contents of a valid token.json that
# contains a refresh_token. Lets the app authenticate headlessly (no browser).
GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.modify"],"token_uri":"https://oauth2.googleapis.com/token"}
